# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- Devin API (https://docs.devin.ai/api-reference/v1/overview) ---
# Leave blank to run the whole system in offline SIMULATE mode.
DEVIN_API_KEY=
DEVIN_API_BASE=https://api.devin.ai/v1

# --- GitHub ---
GITHUB_TOKEN=
# Shared secret configured on the GitHub webhook; enables HMAC verification.
GITHUB_WEBHOOK_SECRET=
TARGET_REPO=sumangit4u/superset
TRIGGER_LABEL=devin-fix

# --- Behaviour ---
# Force simulation even if a key is present:
SIMULATE=false
POLL_INTERVAL_SECONDS=15
DB_PATH=data/runs.db
